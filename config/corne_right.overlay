// ─── VlaCorne – Right Half Overlay (TrackPoint via PS/2 UART) ────────────────
//
// Hardware wiring:
//   TrackPoint pin 1  (CLK)  -> P1.01  (101)
//   TrackPoint pin 2  (RST)  -> P1.06  (D9)
//   TrackPoint pin 6  (DATA) -> P1.02  (102)
//
// P1.01 and P1.02 are used instead of P0.20/P0.17 because:
//   1. The Corne shield's own board overlay enables &i2c0 on P0.17/P0.20 for
//      the OLED at the DTS level — even without CONFIG_ZMK_DISPLAY, the i2c0
//      node remains "okay" and holds those pins, preventing clean pin release
//      during the PS/2 write inhibit sequence.
//   2. P1.01 and P1.02 have zero board-level or shield-level peripheral
//      assignments on nice_nano_v2; they are pure GPIO pads.

// ── Root node ─────────────────────────────────────────────────────────────────
/ {
    mouse_ps2: mouse_ps2 {
        compatible = "zmk,input-mouse-ps2";
        ps2-device = <&uart_ps2>;
        rst-gpios = <&gpio1 6 GPIO_ACTIVE_HIGH>;
        // tp-sensitivity = <160>;  // 0-255, default 128. Uncomment to tune.
    };

    mouse_ps2_input_listener: mouse_ps2_input_listener {
        compatible = "zmk,input-listener-ps2";
        device = <&mouse_ps2>;
        // scale-multiplier = <1>;  // pointer speed scaling: multiplier/divisor
        // scale-divisor = <2>;
    };
};

// ── UART1 pinctrl ─────────────────────────────────────────────────────────────
// Using UART1 (not UART0) because nice_nano_v2 board DTS pre-configures UART0,
// which can prevent pinctrl_apply_state(SLEEP) from fully releasing P0.20 during
// PS/2 write inhibit — causing scl timeout. UART1 has no board-level DTS config
// on nice_nano_v2, so there is no conflict.
//
// The ps2_uart driver hardcodes pins[1] (i.e. the second flattened psel entry
// across all groups) as the TX/SDA pin it reads back at init time for logging
// and for GPIO bit-bang writes.  Zephyr's nRF pinctrl fills pins[] group-by-
// group in DTS order, so:
//   group1 → pins[0]   (must be RX = CLK)
//   group2 → pins[1]   (must be TX = DATA/SDA)
&pinctrl {
    uart1_default: uart1_default {
                    // RX = CLK line -> P1.01 / 101
        group1 {
            psels = <NRF_PSEL(UART_RX, 1, 1)>;
            bias-pull-up;
        };
        // TX = DATA/SDA line -> P1.02 / 102
        group2 {
            psels = <NRF_PSEL(UART_TX, 1, 2)>;
        };
    };

    uart1_sleep: uart1_sleep {
        group1 {
            psels = <NRF_PSEL(UART_RX, 1, 1)>,
                    <NRF_PSEL(UART_TX, 1, 2)>;
            low-power-enable;
        };
    };
};

// ── Interrupt priority table ───────────────────────────────────────────────────
//
// Generated by simulating gen_interrupt_priority_overrides.py
// (infused-kim/zmk fork, app/scripts/) against the nRF52840 SoC DTS.
//
// Why this is needed (from Kconfig.uart):
//   "PS/2 events must be processed within 30–50 µs. […] All other interrupts
//    have to be set to priority 3 to prevent them from delaying the BT
//    interrupts."
//
// The script reads every node with an 'interrupts' property from the final
// zephyr.dts and applies: new_priority = old_priority + 2, except GPIOTE
// which is hardcoded to 0.
//
// nRF52840 base state (NRF_DEFAULT_IRQ_PRIORITY = 1 from nrf_common.dtsi):
//   All SoC peripherals start at priority 1.
//   GPIOTE is the exception: the SoC DTSI sets it to 5 explicitly.
//
// After CONFIG_PS2_UART=y (Kconfig.uart defaults) + our explicit Kconfig:
//   BT LLL   (radio, timer0)      → priority 1  (runtime via NVIC_SetPriority)
//   BT ULL H (rtc0, egu4/swi4)   → priority 2  (runtime)
//   BT ULL L (egu5/swi5)         → priority 3  (runtime, matches DTS below)
//   GPIOTE                        → priority 0  (DTS, PS/2 write clock ISR)
//   All other peripherals         → priority 3  (DTS, non-preemptible by BT LLL/ULL)
//
// Note: DTS overrides for BT-owned peripherals (radio, timer0, rtc0, egu4,
// egu5) are written here but are overridden at runtime by the BT controller
// via NVIC_SetPriority(); they have no net effect on BT scheduling and are
// included only to match the script output exactly.
//
// If a DTS label below causes a compile error, your zephyr.dts may omit that
// peripheral. Remove the failing block and rebuild.
//
// To regenerate from the actual CI zephyr.dts (more accurate for your build):
//   1. Open the GitHub Actions run in a browser → build/corne_right job →
//      step "corne_right – nice_nano_v2 Devicetree file" → copy the full DTS
//      text into a local file (e.g. /tmp/zephyr.dts)
//   2. pip install devicetree
//   3. python app/scripts/gen_interrupt_priority_overrides.py /tmp/zephyr.dts
//   4. Replace the blocks below with the script output.
//
// nRF52840 IRQ map  (irq-number  peripheral  base-priority → new-priority):
//    0  clock / power     1 → 3
//    1  radio             1 → 3   (BT runtime overrides to LLL_PRIO=1)
//    2  uart0             1 → 3
//    3  i2c0 / spi0       1 → 3
//    4  i2c1 / spi1       1 → 3
//    5  nfct              1 → 3
//    6  gpiote            5 → 0   (hardcoded; PS/2 write clock ISR)
//    7  adc               1 → 3
//    8  timer0            1 → 3   (BT runtime overrides to LLL_PRIO=1)
//    9  timer1            1 → 3
//   10  timer2            1 → 3
//   11  rtc0              1 → 3   (BT runtime overrides to ULL_HIGH=2)
//   12  temp              1 → 3
//   13  rng               1 → 3
//   14  ecb               1 → 3
//   15  ccm               1 → 3
//   16  wdt               1 → 3
//   17  rtc1              1 → 3
//   18  qdec              1 → 3
//   19  comp              1 → 3
//   20  egu0 / swi0       1 → 3
//   21  egu1 / swi1       1 → 3
//   22  egu2 / swi2       1 → 3
//   23  egu3 / swi3       1 → 3
//   24  egu4 / swi4       1 → 3   (BT runtime overrides to ULL_HIGH=2)
//   25  egu5 / swi5       1 → 3   (BT runtime overrides to ULL_LOW=3)
//   26  timer3            1 → 3
//   27  timer4            1 → 3
//   28  pwm0              1 → 3
//   29  pdm0              1 → 3
//   33  pwm1              1 → 3
//   34  pwm2              1 → 3
//   35  spi2              1 → 3
//   36  rtc2              1 → 3
//   37  i2s0              1 → 3
//   39  usbd              1 → 3
//   40  uart1             1 → 3
//   41  qspi              1 → 3
//   42  cryptocell        1 → 3
//   45  pwm3              1 → 3
//   47  spi3              1 → 3

&gpiote {
    interrupts = <6 0>;
};

&clock {
    interrupts = <0 3>;
};

&power {
    interrupts = <0 3>;
};

&radio {
    interrupts = <1 3>;
};

&uart0 {
    interrupts = <2 3>;
};

&i2c0 {
    interrupts = <3 3>;
};

&i2c1 {
    interrupts = <4 3>;
};

&nfct {
    interrupts = <5 3>;
};

&adc {
    interrupts = <7 3>;
};

&timer0 {
    interrupts = <8 3>;
};

&timer1 {
    interrupts = <9 3>;
};

&timer2 {
    interrupts = <10 3>;
};

&rtc0 {
    interrupts = <11 3>;
};

&temp {
    interrupts = <12 3>;
};

&rng {
    interrupts = <13 3>;
};

&ecb {
    interrupts = <14 3>;
};

&ccm {
    interrupts = <15 3>;
};

&wdt {
    interrupts = <16 3>;
};

&rtc1 {
    interrupts = <17 3>;
};

&qdec {
    interrupts = <18 3>;
};

&comp {
    interrupts = <19 3>;
};

&egu0 {
    interrupts = <20 3>;
};

&egu1 {
    interrupts = <21 3>;
};

&egu2 {
    interrupts = <22 3>;
};

&egu3 {
    interrupts = <23 3>;
};

&egu4 {
    interrupts = <24 3>;
};

&egu5 {
    interrupts = <25 3>;
};

&timer3 {
    interrupts = <26 3>;
};

&timer4 {
    interrupts = <27 3>;
};

&pwm0 {
    interrupts = <28 3>;
};

&pdm0 {
    interrupts = <29 3>;
};

&pwm1 {
    interrupts = <33 3>;
};

&pwm2 {
    interrupts = <34 3>;
};

&spi2 {
    interrupts = <35 3>;
};

&rtc2 {
    interrupts = <36 3>;
};

&i2s0 {
    interrupts = <37 3>;
};

&usbd {
    interrupts = <39 3>;
};

&uart1 {
    interrupts = <40 3>;
};

&qspi {
    interrupts = <41 3>;
};

&cryptocell {
    interrupts = <42 3>;
};

&pwm3 {
    interrupts = <45 3>;
};

&spi3 {
    interrupts = <47 3>;
};

// ── Disable i2c0 (Corne shield enables it on P0.17/P0.20 for OLED at DTS level)
// Without this, i2c0 holds P0.17 and P0.20 "okay" even with CONFIG_ZMK_DISPLAY
// disabled, which prevents UART from cleanly releasing those pins. Not needed
// here since we're now on P1.01/P1.02, but added as belt-and-suspenders to
// prevent i2c0 from interfering with anything on P0.17/P0.20.
&i2c0 {
    status = "disabled";
};

// ── UART1 peripheral (PS/2 bus) ───────────────────────────────────────────────
// UART1 on P1.01 (CLK/RX) and P1.02 (DATA/TX): pure GPIO pads on the SuperMini
// bottom with no board-level or shield-level peripheral assignments.
&uart1 {
    status = "okay";
    current-speed = <14400>;
    pinctrl-0 = <&uart1_default>;
    pinctrl-1 = <&uart1_sleep>;
    pinctrl-names = "default", "sleep";

    uart_ps2: uart_ps2 {
        compatible = "uart-ps2";
        /// SCL = CLK line -> P1.01 / 101
        scl-gpios = <&gpio1 1 GPIO_ACTIVE_HIGH>;
        // SDA = DATA line -> P1.02 / 102
        sda-gpios = <&gpio1 2 GPIO_ACTIVE_HIGH>;
        status = "okay";
    };
};
